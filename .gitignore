# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright screenshots (auditoría — no son código)
screenshots/

# Reportes de Lighthouse / auditorías (no son código)
reports/

# Archivos de importación one-time / seeds / dumps
*.xlsx
*.csv
*.zip

# PDFs de contrato / acta — no van en el repo
*.pdf
!public/**/*.pdf
